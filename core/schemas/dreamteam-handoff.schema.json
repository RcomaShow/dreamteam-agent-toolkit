{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DreamTeam CHP/2 Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "runId",
    "taskId",
    "contract",
    "status",
    "next"
  ],
  "properties": {
    "protocol": {
      "const": "CHP/2"
    },
    "runId": {
      "type": "string"
    },
    "taskId": {
      "type": "string"
    },
    "contract": {
      "type": "string"
    },
    "status": {
      "enum": [
        "DONE",
        "PARTIAL",
        "BLOCKED",
        "FAILED"
      ]
    },
    "reason": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "source",
          "claim"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "enum": [
              "FACT",
              "DEDUCTION",
              "ASSUMPTION",
              "UNKNOWN"
            ]
          },
          "source": {
            "type": "string"
          },
          "claim": {
            "type": "string"
          }
        }
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "handoffs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "next": {
      "type": "string"
    }
  }
}
