{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DreamTeam DCP/2 Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol",
    "runId",
    "taskId",
    "constitution",
    "profile",
    "goal",
    "tasks",
    "budget",
    "output"
  ],
  "properties": {
    "protocol": {
      "const": "DCP/2"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "taskId": {
      "type": "string",
      "minLength": 1
    },
    "constitution": {
      "const": "DT-C1"
    },
    "profile": {
      "enum": [
        "economy",
        "balanced",
        "offload",
        "quality"
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "allowedScope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "excludedScope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "editableSymbols": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reservedSymbols": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "knownDecisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "reservedDecisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files",
        "deepReads",
        "turns",
        "records",
        "retries"
      ],
      "properties": {
        "files": {
          "type": "integer",
          "minimum": 0
        },
        "deepReads": {
          "type": "integer",
          "minimum": 0
        },
        "turns": {
          "type": "integer",
          "minimum": 1
        },
        "records": {
          "type": "integer",
          "minimum": 1
        },
        "retries": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
